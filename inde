/* ══ SEND ══ */
function sendMsg() {
  const inp = document.getElementById('msgInput');
  const text = inp.value.trim();
  if (!text && S.files.length===0) return;
  if (!S.active) return;

  const msgs = MSGS[S.active];
  const now = new Date();
  const t = now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0');

  // Files
  S.files.forEach(f => {
    if (f.type==='image') msgs.push({id:++S.idCtr,image:f.data,out:true,time:t,status:'sent',reactions:{}});
    else msgs.push({id:++S.idCtr,file:{name:f.name,size:f.size,type:f.type},out:true,time:t,status:'sent',reactions:{}});
  });

  // Text
  if (text) {
    const msg = {id:++S.idCtr,text,out:true,time:t,status:'sent',reactions:{}};
    if (S.replyTo) msg.replyTo = S.replyTo;
    if (S.settings.disappearing) msg.disappear = 30;
    msgs.push(msg);

    if (S.settings.disappearing) {
      const mid = msg.id;
      setTimeout(()=>{ const i=msgs.findIndex(x=>x.id===mid); if(i>-1){msgs.splice(i,1); if(S.active) renderMsgs();} }, 30000);
    }
  }

  // Update contact
  const c = CONTACTS.find(x=>x.id===S.active);
  if (c) { c.last = text||'📎 File'; c.time='now'; }

  inp.value=''; inp.style.height='auto';
  S.files=[]; S.replyTo=null;
  document.getElementById('replyBar').classList.remove('show');
  document.getElementById('imgPrevBar').innerHTML='';
  document.getElementById('imgPrevBar').classList.remove('show');
  document.getElementById('charCount').textContent='';
  inp.classList.remove('warn');

  renderMsgs(); renderContacts(); scrollToBottom(); save();

  // Simulate status progression
  const lastMsg = msgs[msgs.length-1];
  if (lastMsg?.out) {
    setTimeout(()=>{lastMsg.status='delivered'; if(S.active) renderMsgs();}, 1200);
    setTimeout(()=>{lastMsg.status='read'; if(S.active) renderMsgs();}, 3500);
  }

  // Bot reply
  if (S.active <= 4 && text) {
    showTyping();
    const delay = 1400 + Math.random()*2200;
    setTimeout(()=>{
      hideTyping();
      const replies = ['Got it! 👍','Interesting...','Haha 😄','On it!','Makes sense 👌','Love it! 🔥','Sounds good!','Let me check that','Nice one! ✨','Sure thing!'];
      const rep = {id:++S.idCtr,text:replies[Math.floor(Math.random()*replies.length)],out:false,time:t,status:'read',reactions:{}};
      msgs.push(rep);
      if(c){c.last=rep.text;}
      renderMsgs(); renderContacts(); scrollToBottom(); save();
    }, delay);
  }
}

