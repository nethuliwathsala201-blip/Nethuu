function save() {
  try {
    localStorage.setItem('spa_state', JSON.stringify({settings:S.settings,profile:S.profile,mutedChats:S.mutedChats}));
    localStorage.setItem('spa_msgs', JSON.stringify(MSGS));
  } catch(e){}
}

/* apply theme */
document.documentElement.setAttribute('data-theme', S.settings.darkMode ? 'dark' : 'light');

/* ══ CONTACTS ══ */
function renderContacts() {
  const list = document.getElementById('contactList');
  const q = S.query.toLowerCase();
  const now = CONTACTS.filter(c => {
    if (q && !c.name.toLowerCase().includes(q)) return false;
    if (S.tab==='unread' && !c.unread) return false;
    if (S.tab==='groups' && c.type!=='group') return false;
    if (S.tab==='fav' && !c.fav) return false;
    if (S.archivedChats?.[c.id]) return false;
    return true;
  });

  let html = '';
  if (S.tab==='all') {
    const favs = now.filter(c=>c.fav);
    const rest = now.filter(c=>!c.fav);
    if (favs.length) {
      html += `<div class="ci-section">★ Favorites</div>`;
      favs.forEach(c => html += ciHTML(c));
      if (rest.length) html += `<div class="ci-section">All Chats</div>`;
      rest.forEach(c => html += ciHTML(c));
    } else {
      now.forEach(c => html += ciHTML(c));
    }
  } else {
    now.forEach(c => html += ciHTML(c));
  }

  if (!html) html = `<div style="text-align:center;color:var(--text3);font-size:12.5px;padding:30px 16px;">No conversations found</div>`;
  list.innerHTML = html + '<div style="height:70px;"></div>';

  const total = CONTACTS.reduce((a,c)=>a+(c.unread||0),0);
  const bb = document.getElementById('bnBadge');
  if (bb) { bb.textContent=total; bb.style.display=total?'flex':'none'; }
}

function ciHTML(c) {
  const muted = S.mutedChats[c.id];
  return `<div class="ci${S.active===c.id?' active':''}" onclick="openChat(${c.id})">
    <div class="av-wrap">
      <div class="av" style="background:${c.grad}">${c.init}</div>
      <div class="sdot ${c.status}"></div>
    </div>
    <div class="ci-info">
      <div class="ci-name">${c.fav?'★ ':''}<span style="color:${c.fav?'var(--a4)':'inherit'}">${c.name}</span></div>
      <div class="ci-prev">${muted?'🔇 ':''}${c.last}</div>
    </div>
    <div class="ci-meta">
      <div class="ci-time">${c.time}</div>
      ${c.unread&&!muted?`<div class="badge">${c.unread}</div>`:''}
    </div>
  </div>`;
}

function filterContacts(q) { S.query=q; renderContacts(); }
function setTab(el,t) {
  S.tab=t;
  document.querySelectorAll('.stab').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  renderContacts();
}

/* ══ OPEN CHAT ══ */
function openChat(id) {
  S.active = id;
  const c = CONTACTS.find(x=>x.id===id);
  c.unread = 0;
  if (!MSGS[id]) MSGS[id] = [];
  renderContacts();

  document.getElementById('emptyState').style.display = 'none';
  const cv = document.getElementById('chatView');
  cv.style.display = 'flex';

  // Header
  const av = document.getElementById('hdrAv');
  av.style.background = c.grad; av.textContent = c.init;
  document.getElementById('hdrDot').className = 'sdot '+c.status;
  document.getElementById('hdrName').textContent = c.name;
  const stEl = document.getElementById('hdrStatus');
  stEl.textContent = c.status==='online'?'● Online':c.status==='away'?'● Away':'Last seen recently';
  stEl.style.color = c.status==='online'?'var(--green)':c.status==='away'?'var(--yellow)':'var(--text3)';

  renderMsgs();
  scrollToBottom(true);
  updatePinnedBar();

  // Mobile
  document.getElementById('sidebar').classList.remove('open');
  if (window.innerWidth<=768) document.getElementById('backBtn').style.display='flex';
}

/* ══ RENDER MSGS ══ */
function renderMsgs(highlight='') {
  const area = document.getElementById('msgsArea');
  const msgs = MSGS[S.active]||[];
  const c = CONTACTS.find(x=>x.id===S.active);

  let html = `<div class="date-sep"><span>Today</span></div>`;

  msgs.forEach((m,i) => {
    const prev = msgs[i-1];
    const consec = prev && prev.out===m.out && !m.replyTo;
    const showAv = !m.out && !consec;

    let rxnHTML = '';
    const rxns = Object.entries(m.reactions||{}).filter(([,n])=>n>0);
    if (rxns.length) rxnHTML = `<div class="reactions-wrap">${rxns.map(([e,n])=>`<div class="rxn-pill${m.myRxns&&m.myRxns[e]?' mine':''}" onclick="toggleRxn(${m.id},'${e}')">${e}<span>${n}</span></div>`).join('')}</div>`;

    let bubContent = '';
    if (m.image) {
      bubContent += `<div class="img-bubble" onclick="openLightbox('${m.image}')"><img src="${m.image}" alt="img" loading="lazy"></div>`;
    } else if (m.file) {
      bubContent += `<div class="file-bubble"><div class="file-icon">${fileIcon(m.file.type)}</div><div class="file-info"><div class="file-name">${m.file.name}</div><div class="file-size">${m.file.size}</div></div><span>⬇</span></div>`;
    } else {
      const txt = highlight ? m.text.replace(new RegExp(`(${highlight})`,'gi'),'<mark style="background:rgba(124,111,255,0.35);border-radius:3px;padding:0 2px;">$1</mark>') : formatText(m.text);
      bubContent += `<div class="mb${consec?'':m.out?' top-r':' top-l'}${m.pinned?' pinned-msg':''}" oncontextmenu="showCtx(event,${m.id})" onclick="handleBubClick(event,${m.id})">${txt}${m.disappear?`<span class="dis-badge">⏱${m.disappear}s</span>`:''}</div>`;
    }

    const tick = m.out ? `<svg class="tick${m.status==='read'?' blue':''}" viewBox="0 0 18 12" fill="none"><path d="M1 6l4 4L16 1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>${m.status!=='sent'?`<path d="M5 6l4 4 9-9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>`:''}` + `</svg>` : '';

    html += `<div class="mw ${m.out?'out':'in'}${consec?' consecutive':''}" id="m${m.id}">
      ${!m.out ? (showAv ? `<div class="msg-av"><div class="av" style="background:${c.grad};width:28px;height:28px;font-size:9px;">${c.init[0]}</div></div>` : `<div class="msg-av-spacer"></div>`) : ''}
      <div class="mc">
        ${!m.out&&showAv&&c.type==='group'&&m.name?`<div style="font-size:10.5px;font-weight:600;color:var(--a2);padding:0 3px;margin-bottom:1px;">${m.name}</div>`:''}
        ${m.replyTo?`<div class="rq" onclick="jumpToMsg(${m.replyTo.id})"><div class="rq-name">${m.replyTo.name}</div><div class="rq-text">${m.replyTo.text}</div></div>`:''}
        ${bubContent}
        ${rxnHTML}
        <div class="mm"><span>${m.time}</span>${tick}${m.starred?'<span style="font-size:10px;">★</span>':''}</div>
      </div>
    </div>`;
  });

  const dz = document.getElementById('dropZone');
  area.innerHTML = html;
  if (dz) area.insertBefore(dz, area.firstChild);
}

function formatText(t) {
  return (t||'')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.*?)\*/g,'<em>$1</em>')
    .replace(/`([^`]+)`/g,'<code style="background:rgba(255,255,255,0.1);padding:1px 5px;border-radius:4px;font-size:12px;font-family:monospace;">$1</code>')
    .replace(/(https?:\/\/[^\s<]+)/g,'<a href="$1" target="_blank" rel="noopener" onclick="event.stopPropagation()">$1</a>');
}

function fileIcon(type) {
  if (!type) return '📄';
  if (type.includes('pdf')) return '📕';
  if (type.includes('zip')||type.includes('rar')) return '🗜️';
  if (type.includes('doc')) return '📝';
  if (type.includes('image')) return '🖼️';
  if (type.includes('video')) return '🎬';
  return '📎';
}

function scrollToBottom(instant=false) {
  const a = document.getElementById('msgsArea');
