  archivedChats: {},
  starredMsgs: {},
};

/* load from storage */
try {
  const ss = localStorage.getItem('spa_state');
  if (ss) { const p = JSON.parse(ss); Object.assign(S.settings, p.settings||{}); Object.assign(S.profile, p.profile||{}); S.mutedChats=p.mutedChats||{}; S.starredChats=p.starredChats||{}; }
