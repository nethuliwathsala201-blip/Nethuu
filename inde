      <div class="pnl-label">Privacy</div>
      <div class="sr"><div class="sr-icon">✅</div><div class="sr-text"><div class="sr-title">Read Receipts</div><div class="sr-sub">Show when you've read</div></div><div class="tog${s.readReceipts?' on':''}" onclick="toggleSetting('readReceipts')"></div></div>
    </div>
    <div class="pnl-sec">
      <div class="pnl-label">Data</div>
      <div class="sr" onclick="exportData()"><div class="sr-icon">📤</div><div class="sr-text"><div class="sr-title">Export Chats</div><div class="sr-sub">Save as JSON file</div></div></div>
      <div class="sr" onclick="importData()"><div class="sr-icon">📥</div><div class="sr-text"><div class="sr-title">Import Chats</div></div></div>
      <div class="sr danger" onclick="clearAll()"><div class="sr-icon">💣</div><div class="sr-text"><div class="sr-title">Clear All Data</div></div></div>
    </div>
    <div style="text-align:center;padding:20px 0 4px;color:var(--text3);font-size:11px;">SP Aventa v2.0 · HTML/CSS/JS</div>`;
}

function toggleSetting(k) {
  S.settings[k]=!S.settings[k];
  if (k==='darkMode') {
    document.documentElement.setAttribute('data-theme', S.settings.darkMode?'dark':'light');
  }
  save(); renderSettingsPanel();
}

function toggleMuteChat(id) {
  S.mutedChats[id] = !S.mutedChats[id];
  renderContacts(); save();
  toast(S.mutedChats[id]?'Chat muted':'Chat unmuted');
  renderInfoPanel();
}

function toggleFav(id) {
  const c = CONTACTS.find(x=>x.id===id);
  if (!c) return;
  c.fav=!c.fav;
  renderContacts(); renderInfoPanel();
  toast(c.fav?'★ Added to favorites':'Removed from favorites');
}

function clearChat() {
  if (!S.active) return;
  MSGS[S.active]=[]; renderMsgs(); renderInfoPanel(); save();
  toast('Chat cleared');
}

function archiveChat() {
  if (!S.active) return;
  S.archivedChats = S.archivedChats||{};
  S.archivedChats[S.active]=true;
  S.active=null;
  document.getElementById('chatView').style.display='none';
  document.getElementById('emptyState').style.display='flex';
  renderContacts(); save();
  toast('Chat archived');
}

function exportData() {
  const blob=new Blob([JSON.stringify({contacts:CONTACTS,messages:MSGS},null,2)],{type:'application/json'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='sp-aventa-backup.json'; a.click();
  toast('Exported!');
}

function importData() {
  const inp=document.createElement('input'); inp.type='file'; inp.accept='.json';
  inp.onchange=e=>{
    const r=new FileReader(); r.onload=ev=>{
      try { const d=JSON.parse(ev.target.result); if(d.messages) Object.assign(MSGS,d.messages); save(); renderContacts(); if(S.active) renderMsgs(); toast('Imported!'); }
      catch(e){ toast('Invalid file'); }
    }; r.readAsText(e.target.files[0]);
  }; inp.click();
}

function clearAll() {
  localStorage.clear(); toast('Cleared! Reloading...'); setTimeout(()=>location.reload(),1500);
}

/* ══ OVERLAYS ══ */
function openOverlay(id) { document.getElementById(id).classList.add('open'); }
function closeOverlay(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.overlay').forEach(o=>o.addEventListener('click',e=>{ if(e.target===o) o.classList.remove('open'); }));

function createChat() {
  const name = document.getElementById('ncName').value.trim();
  if (!name) { document.getElementById('ncName').style.borderColor='var(--red)'; return; }
  const msg = document.getElementById('ncMsg').value.trim();
  const status = document.getElementById('ncStatus').value.trim();
  const grads=['linear-gradient(135deg,#667eea,#764ba2)','linear-gradient(135deg,#f093fb,#f5576c)','linear-gradient(135deg,#4facfe,#00f2fe)','linear-gradient(135deg,#43e97b,#38f9d7)','linear-gradient(135deg,#fccb90,#d57eeb)'];
  const c={id:Date.now(),name,init:name.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase(),grad:grads[Math.floor(Math.random()*grads.length)],status:'online',last:msg||'New conversation',time:'now',unread:0,type:'dm',fav:false,bio:status||'Contact'};
  CONTACTS.unshift(c);
  MSGS[c.id]=msg?[{id:++S.idCtr,text:msg,out:true,time:'now',status:'sent',reactions:{}}]:[];
  renderContacts(); openChat(c.id); closeOverlay('newChatOv');
  document.getElementById('ncName').value=''; document.getElementById('ncMsg').value=''; document.getElementById('ncStatus').value='';
  toast(`Chat started with ${name}`);
}
document.getElementById('ncMsg').addEventListener('keydown',e=>{ if(e.key==='Enter') createChat(); });

function createGroup() {
  const name = document.getElementById('ngName').value.trim();
  if (!name) return;
  const desc = document.getElementById('ngDesc').value.trim();
  const c={id:Date.now(),name:`${name} 👥`,init:name.substring(0,2).toUpperCase(),grad:'linear-gradient(135deg,#4facfe,#00f2fe)',status:'online',last:'Group created',time:'now',unread:0,type:'group',fav:false,bio:desc||'Group chat'};
  CONTACTS.unshift(c); MSGS[c.id]=[];
  renderContacts(); openChat(c.id); closeOverlay('newGroupOv');
  document.getElementById('ngName').value=''; document.getElementById('ngDesc').value='';
  toast(`Group "${name}" created`);
}

function saveProfile() {
  S.profile.name = document.getElementById('profName').value||'You';
  S.profile.bio = document.getElementById('profBio').value;
  S.profile.status = document.getElementById('profStatusSel').value;
  document.querySelector('.me-name').textContent = S.profile.name;
  save(); closeOverlay('profileOv'); toast('Profile saved');
}

/* ══ CALLS ══ */
function startCall(type) {
  const c = CONTACTS.find(x=>x.id===S.active)||{name:'Unknown',init:'?',grad:'var(--a1)'};
  const callAv = document.getElementById('callAv');
  callAv.style.background=c.grad; callAv.textContent=c.init;
  document.getElementById('callTitle').textContent=(type==='voice'?'📞 Voice':'📹 Video')+' Call';
  document.getElementById('callSub').textContent=`Calling ${c.name}...`;
  document.getElementById('callTimer').textContent='';
  openOverlay('callOv');
  setTimeout(()=>{ document.getElementById('callSub').textContent='Connected'; startCallTimer(); },2000);
}
function startCallTimer() {
  let s=0; clearInterval(S.callInt);
  S.callInt=setInterval(()=>{ s++; const el=document.getElementById('callTimer'); if(el) el.textContent=`${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`; },1000);
}
function endCall() { clearInterval(S.callInt); closeOverlay('callOv'); toast('Call ended'); }
function toggleMute() {
  S.callMuted=!S.callMuted;
  document.getElementById('muteBtn').textContent=S.callMuted?'🔇':'🎤';
  toast(S.callMuted?'Muted':'Unmuted');
}
function toggleSpeaker() {
  S.callSpeaker=!S.callSpeaker;
  document.getElementById('spkBtn').textContent=S.callSpeaker?'🔊':'🔈';
  toast(S.callSpeaker?'Speaker on':'Speaker off');
}

/* ══ THEME ══ */
function toggleTheme() {
  S.settings.darkMode=!S.settings.darkMode;
  document.documentElement.setAttribute('data-theme',S.settings.darkMode?'dark':'light');
  save();
}

/* ══ TOAST ══ */
function toast(msg, dur=2500) {
  const c=document.getElementById('toasts');
  const t=document.createElement('div'); t.className='toast'; t.textContent=msg;
  c.appendChild(t);
  setTimeout(()=>{ t.style.opacity='0'; t.style.transform='translateY(8px) scale(0.9)'; t.style.transition='all 0.3s'; setTimeout(()=>t.remove(),300); },dur);
}

/* ══ MOBILE NAV ══ */
function closeChatMobile() {
  document.getElementById('sidebar').classList.add('open');
}
function mobileNav(view, btn) {
  document.querySelectorAll('.bni').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  if (view==='chats') { document.getElementById('sidebar').classList.add('open'); }
  else if (view==='settings') { togglePanel('settings'); }
}

/* ══ NOTIFICATIONS ══ */
if ('Notification' in window && Notification.permission==='default') {
  Notification.requestPermission();
}

/* ══ INIT ══ */
function init() {
  renderContacts();
  initEP();
  // Auto-open on desktop
  if (window.innerWidth>768) openChat(CONTACTS[0].id);
  else document.getElementById('sidebar').classList.add('open');
}

init();
</script>
</body>
</html>
