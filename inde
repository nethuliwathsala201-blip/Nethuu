/* ══ FILES ══ */
function triggerFile() { document.getElementById('fileInput').click(); }
function handleFiles(e) {
  Array.from(e.target.files).forEach(f => {
    if (f.type.startsWith('image/')) {
      const r = new FileReader();
      r.onload = ev => { S.files.push({type:'image',data:ev.target.result}); renderPrev(); };
      r.readAsDataURL(f);
    } else {
      const sz = f.size > 1048576 ? (f.size/1048576).toFixed(1)+' MB' : (f.size/1024).toFixed(0)+' KB';
      S.files.push({type:f.type||'file',name:f.name,size:sz});
      renderPrev();
    }
  });
  e.target.value='';
}
function renderPrev() {
  const bar = document.getElementById('imgPrevBar');
  bar.innerHTML = S.files.map((f,i)=> f.type==='image'
    ? `<div class="ipv"><img src="${f.data}"><button class="ipv-rm" onclick="rmFile(${i})">✕</button></div>`
    : `<div class="ipv" style="display:flex;align-items:center;justify-content:center;font-size:20px;background:var(--bg3);">${fileIcon(f.type)}<button class="ipv-rm" onclick="rmFile(${i})">✕</button></div>`
  ).join('');
  bar.classList.toggle('show', S.files.length>0);
}
function rmFile(i) { S.files.splice(i,1); renderPrev(); }

// Paste image
document.addEventListener('paste', e => {
  if (!S.active) return;
  const items = e.clipboardData?.items||[];
  for (const item of items) {
    if (item.type.startsWith('image/')) {
      const r = new FileReader();
      r.onload = ev => { S.files.push({type:'image',data:ev.target.result}); renderPrev(); };
      r.readAsDataURL(item.getAsFile());
    }
  }
});

// Drag & drop
function handleDragOver(e) { e.preventDefault(); document.getElementById('dropZone').classList.add('active'); }
function handleDragLeave() { document.getElementById('dropZone').classList.remove('active'); }
function handleDrop(e) {
  e.preventDefault();
  document.getElementById('dropZone').classList.remove('active');
  if (!S.active) return;
  Array.from(e.dataTransfer.files).forEach(f => {
    if (f.type.startsWith('image/')) {
      const r = new FileReader(); r.onload=ev=>{S.files.push({type:'image',data:ev.target.result});renderPrev();}; r.readAsDataURL(f);
    } else {
      const sz = f.size>1048576?(f.size/1048576).toFixed(1)+' MB':(f.size/1024).toFixed(0)+' KB';
      S.files.push({type:f.type||'file',name:f.name,size:sz}); renderPrev();
    }
  });
}

